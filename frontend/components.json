{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": true,
  "tsx": false,
  "tailwind": {
    "config": "",
    "css": "src/app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@efferd": "https://efferd.com/r/{style}/{name}.json",
    "@shadcn-space": "https://shadcnspace.com/r/{name}.json",
    "@reui": "https://reui.io/r/{style}/{name}.json",
    "@bundui": {
      "url": "https://bundui.io/api/registry/{name}.json"
    }
  }
}
